# Database
DATABASE_URL=postgresql://user:password@localhost:5432/astor

# DigitalOcean Inference (https://inference.do-ai.run/v1/)
DIGITAL_OCEAN_MODEL_ACCESS_KEY=your-do-model-access-key-here

# LLM model for agent reasoning (default: deepseek-v4-pro)
# This is separate from STAGEHAND_MODEL — this one does tool-calling decisions,
# Stagehand's model does browser vision (act/observe/extract).
LLM_MODEL=deepseek-v4-pro

# Browserbase (optional — if set, uses Browserbase cloud browsers; if unset, uses local Playwright)
BROWSERBASE_API_KEY=

# Stagehand model override (default: anthropic/anthropic-claude-4.5-sonnet — a vision model
# is REQUIRED for browser automation). Format is "<stagehand-provider>/<DO-model-id>".
# The anthropic provider is the only Stagehand provider whose wire format DigitalOcean's
# gateway implements to spec: "openai/..." hits /v1/responses (gateway returns non-spec
# JSON → "Invalid JSON response"), openai-compatible providers use json_object mode
# (errors unless prompts contain "json").
# Do NOT use deepseek-v4-pro here — it's a reasoning model without vision support.
STAGEHAND_MODEL=anthropic/anthropic-claude-4.5-sonnet

# Server
PORT=3001
FRONTEND_URL=http://localhost:5183
