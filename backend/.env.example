# Database
DATABASE_URL=postgresql://user:password@localhost:5432/astor

# DigitalOcean Inference (https://inference.do-ai.run/v1/)
DIGITAL_OCEAN_MODEL_ACCESS_KEY=your-do-model-access-key-here

# LLM model for agent reasoning (default: deepseek-v4-pro)
# This is separate from STAGEHAND_MODEL — this one does tool-calling decisions,
# Stagehand's model does browser vision (act/observe/extract).
LLM_MODEL=deepseek-v4-pro

# Browserbase (optional — if set, uses Browserbase cloud browsers; if unset, uses local Playwright)
BROWSERBASE_API_KEY=

# Stagehand model override (default: gpt-4o — a vision model is REQUIRED for browser automation)
# Options: gpt-4o, gpt-4o-mini, claude-3.5-sonnet
# Do NOT use deepseek-v4-pro here — it's a reasoning model without vision support.
STAGEHAND_MODEL=gpt-4o

# Server
PORT=3001
