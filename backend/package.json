{
  "name": "astor-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "migrate": "tsx src/db/migrations/run.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "tools:local": "tsx src/tools/__mocks__/localRun.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@browserbasehq/sdk": "^2.15.0",
    "@browserbasehq/stagehand": "^3.6.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "openai": "^6.46.0",
    "pg": "^8.13.0",
    "uuid": "^10.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/pg": "^8.11.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.10"
  }
}
